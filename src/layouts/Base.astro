---
import '../styles/global.css';

interface Props {
  title?: string;
  currentPage?: string;
}

const { title = 'Cara Colgate, LICSW', currentPage = '' } = Astro.props;

const navLinks = [
  { label: 'Home', href: '/', key: 'home' },
  { label: 'About Me', href: '/about/', key: 'about' },
  { label: 'Children & Teens', href: '/children-teens/', key: 'children' },
  { label: 'Adults', href: '/adults/', key: 'adults' },
  { label: 'More Info', href: '/more-info/', key: 'info' },
  { label: 'Connect', href: '/connect/', key: 'connect' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Cara Colgate, LICSW – Licensed Clinical Social Worker providing therapy for adults, children, and teens in Wellesley, MA." />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>

    <header>
      <div class="site-title">
        <a href="/">Cara Colgate, LICSW</a>
      </div>
      <nav>
        <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <ul class="nav-list">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class={currentPage === link.key ? 'active' : ''}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>51 River Street, Wellesley MA 02481</p>
      <p>(617) 903-8115 | <a href="mailto:cara@caracolgate.com">cara@caracolgate.com</a></p>
      <p class="disclaimer">Please note: The use of this website does not constitute a therapist-client relationship.</p>
    </footer>

  </body>
</html>

<script>
  // Mobile nav toggle
  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
  const navList = document.querySelector('.nav-list') as HTMLElement;
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    navList.classList.toggle('open');
  });
</script>

<style>
  header {
    background: var(--bg);
    padding: 1.5rem 2rem 0;
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
  }

  .site-title {
    text-align: center;
    margin-bottom: 1rem;
  }

  .site-title a {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .site-title a:hover {
    color: var(--text);
  }

  nav {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .nav-list {
    list-style: none;
    padding: 0;
    display: flex;
    justify-content: center;
    gap: 0;
    flex-wrap: wrap;
  }

  .nav-list li a {
    display: block;
    padding: 0.65rem 1.1rem;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s;
    border-radius: 4px;
  }

  .nav-list li a:hover {
    color: var(--accent);
  }

  .nav-list li a.active {
    background: var(--nav-active-bg);
    color: var(--accent);
  }

  /* Mobile hamburger */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
  }

  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
  }

  @media (max-width: 600px) {
    header {
      padding: 1.2rem 1rem 0;
    }

    nav {
      padding: 0.5rem 0;
    }

    .nav-toggle {
      display: flex;
    }

    .nav-list {
      display: none;
      flex-direction: column;
      gap: 0;
      padding: 0.5rem 0;
    }

    .nav-list.open {
      display: flex;
    }

    .nav-list li a {
      padding: 0.6rem 1rem;
    }
  }

  main {
    flex: 1;
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
    padding: 2rem 2rem;
  }

  footer {
    background: var(--bg-footer);
    border-top: 1px solid var(--border);
    text-align: center;
    padding: 1.5rem 2rem;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    line-height: 1.8;
  }

  footer a {
    color: var(--text-muted);
  }

  .disclaimer {
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    margin-top: 0.25rem;
  }
</style>
